# ── Core ──────────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword_dev
DB_NAME=golf_marketing
DB_USER=golf_user
DB_PASSWORD=golf_dev_pass
JWT_SECRET=CHANGE_ME_min32chars_strong_key_here
JWT_REFRESH_SECRET=CHANGE_ME_refresh_min32chars_strong
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:5000

# ── Email ──────────────────────────────────────────────────────────────────────
# MAIL_PROVIDER=smtp (local dev) | graph (Microsoft 365)
MAIL_PROVIDER=smtp

# ── Redis (optional but recommended — enables BullMQ campaign queue) ───────────
# Already wired in docker-compose.yml; set to enable BullMQ in the backend:
# REDIS_HOST=redis     # (already set automatically in docker-compose.yml)
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── AWS S3 / MinIO (optional — enables cloud file storage for uploads) ─────────
# Leave unset to use the local filesystem (fine for dev/single-instance).
# For production: replace with real AWS values. For local MinIO testing:
#   - Add a MinIO service to docker-compose.yml (see docs)
#   - Set AWS_ENDPOINT_URL=http://minio:9000 and AWS_S3_FORCE_PATH_STYLE=true
# AWS_S3_BUCKET=golf-huub-uploads
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_ENDPOINT_URL=          # Set to MinIO URL for local testing
# AWS_S3_FORCE_PATH_STYLE=   # Set to 'true' for MinIO
# AWS_S3_PUBLIC=true         # Set to 'false' if Block Public Access is on + you use CloudFront
