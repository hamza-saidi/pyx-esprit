# Production Environment Variables
# Copy this file to .env in your backend folder and fill in your production values

# Database Configuration
DB_HOST=your-mysql-host.com
DB_USER=your-database-username
DB_PASSWORD=your-database-password
DB_NAME=golf_marketing_db
DB_PORT=3306

# Server Configuration
PORT=5000
NODE_ENV=production
PUBLIC_BASE_URL=https://yourdomain.com  # Public base URL used in email links (tracking/media). Must NOT be localhost.

# JWT Secret (generate a strong secret)
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (for campaigns)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-email-password
EMAIL_FROM=noreply@yourdomain.com

# CORS Configuration
FRONTEND_URL=https://yourdomain.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760









