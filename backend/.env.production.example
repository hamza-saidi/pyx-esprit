NODE_ENV=production
PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=golf_huub_db

# CRITICAL: Replace with your actual production domain
FRONTEND_URL=https://your-domain.com
PUBLIC_BASE_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com/api

# Email Settings
MAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# GrapesJS Content Limit
JSON_LIMIT=50mb
