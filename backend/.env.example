# =============================================================
# backend/.env.example — copier en backend/.env et remplir
# JAMAIS commiter le .env réel (contient des secrets)
# =============================================================

# ── Serveur ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=golf_marketing
DB_USER=golf_user
DB_PASSWORD=changeme
# Mot de passe root (utilisé uniquement par docker-compose pour créer la DB)
DB_ROOT_PASSWORD=changeme_root

# ── JWT (générer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=change_me_at_least_48_random_chars
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret_48_chars

# ── Redis (BullMQ queue + session store) ─────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=           # décommenter si Redis est sécurisé

# ── URLs publiques ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:5000

# ── Upload de fichiers ────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760     # 10 Mo en octets

# ── Provider email ────────────────────────────────────────────
# Valeurs possibles: smtp | graph | mock (pour les tests)
MAIL_PROVIDER=smtp

# SMTP (si MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=smtp_password
# SMTP_FROM=noreply@example.com

# Microsoft Graph / Azure AD (si MAIL_PROVIDER=graph)
# GRAPH_TENANT_ID=your-azure-tenant-id
# GRAPH_CLIENT_ID=your-azure-app-client-id
# GRAPH_CLIENT_SECRET=your-azure-app-secret
# GRAPH_SENDER_EMAIL=noreply@yourdomain.com

# ── IA — Groq (génération contenu email) ─────────────────────
# GROQ_API_KEY=gsk_...

# ── Sécurité CSRF ─────────────────────────────────────────────
# CSRF_SECRET=change_me_csrf_secret   # si configuré séparément de JWT_SECRET
