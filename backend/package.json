{
  "name": "pylon-pyx-backend",
  "version": "1.0.0",
  "description": "Pylon Pyx — Email Marketing Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:unit": "jest --testPathIgnorePatterns=tests/integration",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "generate:auto-tags": "node generate-auto-tags.js",
    "migrate-db": "node migrate-db.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/integration/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 15000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "utils/jwt.js",
      "utils/queryBuilder.js",
      "utils/pick.js",
      "utils/tenantContext.js",
      "models/hooks/tenantScopeHooks.js",
      "middleware/csrf.js",
      "use-cases/**/*.js",
      "repositories/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "use-cases/errors.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 20
      },
      "./utils/tenantContext.js": {
        "functions": 100,
        "lines": 100
      },
      "./models/hooks/tenantScopeHooks.js": {
        "functions": 50,
        "lines": 60
      },
      "./middleware/csrf.js": {
        "functions": 100,
        "lines": 100
      },
      "./utils/pick.js": {
        "functions": 100,
        "lines": 100
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "verbose": true
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@azure/identity": "^4.12.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "faker": "^5.5.3",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.8",
    "openai": "^5.20.2",
    "sequelize": "^6.35.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
